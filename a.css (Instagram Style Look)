body {
    font-family: Arial, sans-serif;
    text-align: center;
    background-color: #fafafa;
}

.stories {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 50px;
}

.story {
    width: 110px;
    text-align: center;
}

.story img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 4px solid pink;
    padding: 2px;
}

.story p {
    margin-top: 5px;
    font-size: 14px;
}

/* Slide pages */
.slide {
    background-color: black;
    color: white;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

a {
    color: lightblue;
    margin-top: 20px;
}
